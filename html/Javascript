<style>
        /* Styles for the floating card */
        #whatsapp-card {
            position: fixed;
            bottom: 120px;
            right: 30px;
            background: white;
            padding: 15px 20px;
            border-radius: 10px;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2);
            font-family: Arial, sans-serif;
            width: 250px;
            display: none;
            flex-direction: column;
            align-items: flex-start;
            transition: opacity 1s ease-in-out;
            opacity: 0;
            z-index: 9999;
        }

        #whatsapp-card h4 {
            font-size: 16px;
            color: #25d366;
            margin: 0;
        }

        #whatsapp-card p {
            margin: 5px 0 10px;
            font-size: 14px;
            color: #333;
        }

        #whatsapp-card span {
            font-size: 12px;
            color: #128c7e;
            font-weight: bold;
        }

        /* Close button style */
        #close-button {
            background: none;
            border: none;
            color: #ff0000;
            font-size: 18px;
            cursor: pointer;
            position: absolute;
            top: 5px;
            right: 5px;
        }

        /* WhatsApp Button Styles */
        #whatsapp-widget {
            position: fixed;
            bottom: 30px;
            right: 30px;
            background: linear-gradient(45deg, red, orange, yellow, green, blue, indigo, violet);
            background-size: 300%;
            color: white;
            width: 90px;
            height: 90px;
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 36px;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.3);
            cursor: pointer;
            animation: rainbow 3s infinite linear, bounce-high 1.5s infinite;
            z-index: 9999;
        }

        #whatsapp-widget:hover {
            transform: scale(1.2);
        }

        /* Keyframes for Rainbow Animation */
        @keyframes rainbow {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        /* Bounce Animation */
        @keyframes bounce-high {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-20px); }
        }
    </style>



    <!-- Floating Card -->
    <div id="whatsapp-card">
        <button id="close-button">&#215;</button>
        <h4>Mulastar Customer Service</h4>
        <span>🟢 Online</span>
        <p id="message">How can I help you, dear customer?</p>
        <button onclick="openWhatsApp()" style="
            background: #25d366;
            color: white;
            padding: 10px 15px;
            font-size: 14px;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.2);
        ">Send Message On WhatsApp.</button>
    </div>

    <!-- WhatsApp Button -->
    <div id="whatsapp-widget" onclick="openWhatsApp()">
        💬
    </div>

    <!-- Custom Sound -->
    <audio id="popup-sound">
        <source src="https://kwetucloud.com/uploads/pop-up-bubble-gfx-sounds-1-00-00_1738374360.mp3" type="audio/wav">
    </source></audio>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            let card = document.getElementById("whatsapp-card");
            let sound = document.getElementById("popup-sound");
            let closeButton = document.getElementById("close-button");
            let messageElement = document.getElementById("message");

            let messages = [
"Welcome Dear Customer 🙋 How Can I help you ??😊",
                "Hello! Join now Mulastar to receive your welcome bonus 🎉",
                "Let today be the day 😊 Activate your account and start earning!",
                "Daily Offer! Join and Get Cashback (94% of Joining fee) 🔥",
                "Sign up today & Earn at least 2k per day! Tap Register MulaStar at the top!"
            ];
            
            let index = 0;

            function showCardWithSound() {
                card.style.display = "flex";
                card.style.opacity = 1;
                messageElement.innerText = messages[index];

                sound.play().catch(error => console.log("Autoplay prevented:", error));

                setTimeout(hideCard, 5000); // Hide after 5 seconds
            }

            function hideCard() {
                card.style.opacity = 0;
                setTimeout(() => {
                    card.style.display = "none";

                    index = (index + 1) % messages.length;
                    setTimeout(showCardWithSound, 5000); // Show new message after 5 seconds
                }, 1000);
            }

            function closeCard() {
                sound.play();
                card.style.opacity = 0;
                setTimeout(() => {
                    card.style.display = "none";
                }, 1000);
            }

            // Start the cycle after 1 second
            setTimeout(showCardWithSound, 1000);

            closeButton.addEventListener("click", closeCard);
        });

        function openWhatsApp() {
            const phoneNumber = "+254103211520";
            const message = "Hello Agent JulyusKe Am Interested in MulasStar";
            const whatsappLink = `https://wa.me/${phoneNumber}?text=${encodeURIComponent(message)}`;
            window.open(whatsappLink, "_blank");
        }
    </script>
